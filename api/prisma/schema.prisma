// Schema VestiFlow — PostgreSQL su Supabase.
// Specchia i modelli di dominio del frontend Angular (src/app/core/models):
// multi-tenant ovunque, stock per location (semantica Shopify), denaro in
// unità minori intere, movimenti tracciati con origine.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  owner
  admin
  manager
  clerk
}

/// Canale ecommerce abilitato per il tenant (scelto in provisioning piattaforma).
enum TenantChannelProfile {
  gestionale
  shopify
  tiktok_shop
}

enum ProductStatus {
  draft
  active
  archived
}

/// Provenienza catalogo: chi possiede i campi ecommerce condivisi con Shopify.
enum CatalogOrigin {
  vestiflow
  shopify
}

/// Come il prodotto è stato collegato a Shopify (import pull vs push gestionale).
enum ShopifyCatalogLinkKind {
  imported
  pushed
}

enum StockMovementType {
  load
  unload
  transfer
  adjustment
  sale
  return
}

enum AdjustmentDirection {
  increase
  decrease
}

/// Origine del movimento: manuale (utente gestionale) o sync canale vendita.
enum MovementOrigin {
  manual
  shopify
  tiktok
  /// Vendita o storno registrati al banco nel profilo solo gestionale.
  vestiflow_pos
}

enum ShopifySyncStatus {
  not_connected
  synced
  out_of_sync
  syncing
  error
}

enum ShopifyConnectionStatus {
  not_connected
  connected
  reauth_required
  error
}

enum TikTokConnectionStatus {
  not_connected
  connected
  reauth_required
  error
}

enum TikTokSyncStatus {
  not_connected
  synced
  out_of_sync
  syncing
  error
}

enum SupplierOrderStatus {
  draft
  sent
  partially_received
  received
  cancelled
}

enum SalesOrderFinancialStatus {
  pending
  authorized
  paid
  partially_refunded
  refunded
  voided
}

enum SalesOrderFulfillmentStatus {
  unfulfilled
  partially_fulfilled
  fulfilled
}

enum SalesOrderSource {
  shopify_online
  shopify_pos
  manual
}

/// Stato di una sessione di inventario fisico (conteggio annuale/spot).
enum InventoryCountStatus {
  in_progress
  review
  completed
  cancelled
}

// ── Tenant & utenti ──────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  channelProfile TenantChannelProfile @default(shopify) @map("channel_profile")
  legalName    String? @map("legal_name")
  vatNumber    String? @map("vat_number")
  fiscalCode   String? @map("fiscal_code")
  phone        String?
  pec          String?
  sdiCode      String? @map("sdi_code")
  addressLine1 String? @map("address_line1")
  addressLine2 String? @map("address_line2")
  city         String?
  province     String?
  postalCode   String? @map("postal_code")
  countryCode  String? @map("country_code")
  /// Sedi operative incluse nel contratto (max 10).
  licensedLocationCount Int @default(1) @map("licensed_location_count")
  /// Blocco scelta sedi attive: dopo il primo salvataggio cliente o migrazione con sedi già attive.
  locationSelectionLocked Boolean @default(false) @map("location_selection_locked")
  /// Sblocco one-shot concesso dall'admin piattaforma per un nuovo round di selezione.
  locationSelectionChangeGranted Boolean @default(false) @map("location_selection_change_granted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users              User[]
  stores             Store[]
  locations          Location[]
  products           Product[]
  productImages      ProductImage[]
  variants           ProductVariant[]
  inventoryLevels    InventoryLevel[]
  stockMovements     StockMovement[]
  inventoryCounts    InventoryCountSession[]
  suppliers          Supplier[]
  supplierOrders     SupplierOrder[]
  customers          Customer[]
  salesOrders        SalesOrder[]
  shopifyConnection  ShopifyConnection?
  shopifyCredential  ShopifyCredential?
  shopifyOAuthStates ShopifyOAuthState[]
  tiktokConnection   TikTokConnection?
  tiktokCredential   TikTokCredential?
  tiktokOAuthStates  TikTokOAuthState[]
  supportSessionsAsTarget SupportSession[] @relation("SupportSessionTarget")

  @@map("tenants")
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  /// Id dell'utente in Supabase Auth (sub del JWT). L'identità vive lì,
  /// qui vivono profilo applicativo e ruolo.
  authUserId  String?  @unique @map("auth_user_id") @db.Uuid
  email       String
  displayName        String   @map("display_name")
  role               UserRole @default(clerk)
  /// URL pubblico foto profilo (Supabase Storage).
  avatarUrl          String?  @map("avatar_url")
  avatarStoragePath  String?  @map("avatar_storage_path")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant      @relation(fields: [tenantId], references: [id])
  stores UserStore[]
  supportSessionsAsOperator SupportSession[] @relation("SupportSessionOperator")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// Sessione assistenza: operatore piattaforma che accede al gestionale di un cliente.
model SupportSession {
  id             String    @id @default(uuid()) @db.Uuid
  operatorUserId String    @map("operator_user_id") @db.Uuid
  targetTenantId String    @map("target_tenant_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at")
  endedAt        DateTime? @map("ended_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  operator     User   @relation("SupportSessionOperator", fields: [operatorUserId], references: [id])
  targetTenant Tenant @relation("SupportSessionTarget", fields: [targetTenantId], references: [id])

  @@index([operatorUserId, endedAt])
  @@index([targetTenantId])
  @@map("support_sessions")
}

model Store {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  code      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  locations Location[]
  users     UserStore[]

  @@index([tenantId])
  @@map("stores")
}

/// Accesso utente → negozi (UI: selettore e permessi per store).
model UserStore {
  userId  String @map("user_id") @db.Uuid
  storeId String @map("store_id") @db.Uuid

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
  @@map("user_stores")
}

// ── Location (porta l'inventario, semantica Shopify) ────────────────────────

model Location {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  code      String?
  isActive  Boolean  @default(true) @map("is_active")
  /// Sede operativa in VestiFlow (entro licensedLocationCount del tenant).
  licensedInVf Boolean @default(false) @map("licensed_in_vf")
  /// Store servito da questa location (un magazzino può non averene).
  storeId   String?  @map("store_id") @db.Uuid
  // Indirizzo denormalizzato (display/etichette, non entità a sé).
  addressLine1 String? @map("address_line1")
  addressLine2 String? @map("address_line2")
  city         String?
  province     String?
  postalCode   String? @map("postal_code")
  countryCode  String? @map("country_code")
  // Collegamento Shopify Location: solo id pubblici, nessun segreto.
  shopifyLocationId String?            @map("shopify_location_id")
  shopifySyncStatus ShopifySyncStatus  @default(not_connected) @map("shopify_sync_status")
  shopifyLastSyncAt DateTime?          @map("shopify_last_sync_at")
  shopifyLastError  String?            @map("shopify_last_error")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  store             Store?           @relation(fields: [storeId], references: [id])
  inventoryLevels   InventoryLevel[]
  movements         StockMovement[]  @relation("MovementLocation")
  incomingTransfers StockMovement[]  @relation("MovementTargetLocation")
  supplierOrders    SupplierOrder[]
  inventoryCounts   InventoryCountSession[]

  @@index([tenantId])
  @@map("locations")
}

// ── Catalogo: prodotti e varianti ────────────────────────────────────────────

model Product {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  name        String
  description String?
  brand       String?
  /// Tipo prodotto Shopify (REST product_type) — organizzazione interna negozio.
  category    String?
  /// Categoria Standard Product Taxonomy (GraphQL), es. gid://shopify/TaxonomyCategory/...
  shopifyTaxonomyCategoryId       String? @map("shopify_taxonomy_category_id")
  shopifyTaxonomyCategoryFullName String? @map("shopify_taxonomy_category_full_name")
  season      String?
  /// Tag prodotto (forma Shopify: lista normalizzata, es. ['estate','donna']).
  tags        String[]      @default([])
  /// SEO importato da Shopify (metafields global title_tag / description_tag).
  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description")
  /// Collezioni Shopify collegate [{ id, title }] — read-only lato sync.
  shopifyCollections Json @default("[]") @map("shopify_collections")
  /// Metafields Shopify importati [{ namespace, key, value, type? }] — snapshot.
  shopifyMetafields  Json @default("[]") @map("shopify_metafields")
  /// Attributi categoria Shopify [{ attributeId, key, namespace, values: [{ id, name }] }].
  shopifyCategoryMetafields Json @default("[]") @map("shopify_category_metafields")
  status      ProductStatus @default(draft)
  /// Chi possiede il catalogo ecommerce: vestiflow (creato in gestionale) o shopify (import).
  catalogOrigin CatalogOrigin @default(vestiflow) @map("catalog_origin")
  /// Modalità collegamento Shopify; null su dati legacy pre-migrazione.
  shopifyCatalogLinkKind ShopifyCatalogLinkKind? @map("shopify_catalog_link_kind")
  /// Assi opzione (max 3, vincolo Shopify): [{ name: 'Taglia', values: ['S','M'] }]
  options     Json          @default("[]")
  // Collegamento Shopify Product: solo id pubblici.
  shopifyProductId  String?           @map("shopify_product_id")
  shopifySyncStatus ShopifySyncStatus @default(not_connected) @map("shopify_sync_status")
  shopifyLastSyncAt DateTime?         @map("shopify_last_sync_at")
  shopifyLastError  String?           @map("shopify_last_error")
  /// Categoria TikTok Shop (id Partner API) — obbligatoria per push catalogo.
  tiktokCategoryId  String?           @map("tiktok_category_id")
  tiktokProductId   String?           @map("tiktok_product_id")
  tiktokSyncStatus  TikTokSyncStatus  @default(not_connected) @map("tiktok_sync_status")
  tiktokLastSyncAt  DateTime?         @map("tiktok_last_sync_at")
  tiktokLastError   String?           @map("tiktok_last_error")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  variants ProductVariant[]
  images   ProductImage[]

  @@index([tenantId, status])
  @@index([tenantId, name])
  @@index([tenantId, shopifyProductId])
  @@index([tenantId, tiktokProductId])
  @@map("products")
}

model ProductImage {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  /// URL pubblico (Supabase Storage o CDN Shopify).
  url            String
  /// Path nel bucket Supabase; null se l'immagine proviene solo da Shopify.
  storagePath    String?  @map("storage_path")
  altText        String?  @map("alt_text")
  sortOrder      Int      @default(0) @map("sort_order")
  shopifyImageId String?  @map("shopify_image_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@index([tenantId])
  @@map("product_images")
}

model ProductVariant {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  /// Univoco per tenant: regola interna del gestionale. In import da Shopify
  /// gli SKU duplicati/vuoti NON rompono il sync: vanno gestiti come anomalie
  /// PRIMA dell'insert (regole-gestionale, clausola di realtà).
  sku       String
  /// Valori opzione (forma Shopify selectedOptions): [{ name, value }]
  optionValues Json @default("[]") @map("option_values")
  barcode   String?
  // Denaro in unità minori intere (mai float).
  currency               String @default("EUR")
  sellingPriceMinor      Int    @map("selling_price_minor")
  purchasePriceMinor     Int?   @map("purchase_price_minor")
  compareAtPriceMinor    Int?   @map("compare_at_price_minor")
  // Collegamento Shopify: variante e inventory item.
  shopifyVariantId         String? @map("shopify_variant_id")
  shopifyInventoryItemId   String? @map("shopify_inventory_item_id")
  /// SKU id TikTok Shop (Partner API) per sync giacenze.
  tiktokSkuId              String? @map("tiktok_sku_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryLevels InventoryLevel[]
  movements       StockMovement[]
  countLines      InventoryCountLine[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([productId])
  @@index([tenantId])
  @@map("product_variants")
}

// ── Inventario ───────────────────────────────────────────────────────────────

/// Giacenza per variante × location. Quantity states allineati a Shopify;
/// available può essere negativo (oversell).
model InventoryLevel {
  id           String @id @default(uuid()) @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  variantId    String @map("variant_id") @db.Uuid
  locationId   String @map("location_id") @db.Uuid
  onHand       Int    @default(0) @map("on_hand")
  available    Int    @default(0)
  committed    Int    @default(0)
  incoming     Int    @default(0)
  reserved     Int    @default(0)
  minThreshold Int    @default(0) @map("min_threshold")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  location Location       @relation(fields: [locationId], references: [id])

  @@unique([variantId, locationId])
  @@index([tenantId])
  @@index([tenantId, locationId])
  @@index([locationId])
  @@map("inventory_levels")
}

/// Sessione di inventario fisico per location (conteggio spot o annuale).
model InventoryCountSession {
  id            String               @id @default(uuid()) @db.Uuid
  tenantId      String               @map("tenant_id") @db.Uuid
  locationId    String               @map("location_id") @db.Uuid
  name          String
  notes         String?
  status        InventoryCountStatus @default(in_progress)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  completedAt   DateTime?            @map("completed_at")
  createdByName String               @map("created_by_name")

  tenant   Tenant               @relation(fields: [tenantId], references: [id])
  location Location             @relation(fields: [locationId], references: [id])
  lines    InventoryCountLine[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("inventory_count_sessions")
}

/// Riga conteggio: snapshot giacenza di sistema vs quantità contata.
model InventoryCountLine {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  sessionId       String   @map("session_id") @db.Uuid
  variantId       String   @map("variant_id") @db.Uuid
  sku             String
  productName     String   @map("product_name")
  systemQuantity  Int      @map("system_quantity")
  countedQuantity Int?     @map("counted_quantity")
  updatedAt       DateTime @updatedAt @map("updated_at")

  session InventoryCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  variant ProductVariant      @relation(fields: [variantId], references: [id])

  @@unique([sessionId, variantId])
  @@index([sessionId])
  @@index([tenantId])
  @@map("inventory_count_lines")
}

/// Log immutabile: ogni modifica inventariale produce una riga qui
/// (regole-gestionale: mai update silenziosi). Append-only by design.
model StockMovement {
  id               String              @id @default(uuid()) @db.Uuid
  tenantId         String              @map("tenant_id") @db.Uuid
  type             StockMovementType
  origin           MovementOrigin      @default(manual)
  variantId        String              @map("variant_id") @db.Uuid
  /// Snapshot SKU al momento del movimento (audit anche se la variante cambia).
  sku              String
  locationId       String              @map("location_id") @db.Uuid
  /// Solo trasferimenti: destinazione.
  targetLocationId String?             @map("target_location_id") @db.Uuid
  quantity         Int
  direction        AdjustmentDirection?
  reason           String?
  /// Riferimento esterno (es. id ordine Shopify che ha generato la vendita).
  externalRef      String?             @map("external_ref")
  createdAt        DateTime            @default(now()) @map("created_at")
  createdById      String?             @map("created_by_id") @db.Uuid
  /// Snapshot del nome operatore (audit stabile anche se l'utente cambia nome).
  createdByName    String              @map("created_by_name")

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  variant        ProductVariant @relation(fields: [variantId], references: [id])
  location       Location       @relation("MovementLocation", fields: [locationId], references: [id])
  targetLocation Location?      @relation("MovementTargetLocation", fields: [targetLocationId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, locationId, createdAt(sort: Desc)])
  @@index([variantId])
  @@index([locationId])
  @@map("stock_movements")
}

// ── Fornitori e ordini fornitore ─────────────────────────────────────────────

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  orders SupplierOrder[]

  @@index([tenantId])
  @@map("suppliers")
}

model SupplierOrder {
  id         String              @id @default(uuid()) @db.Uuid
  tenantId   String              @map("tenant_id") @db.Uuid
  /// Riferimento leggibile (es. 'PO-2026-0042'), univoco per tenant.
  reference  String
  supplierId String              @map("supplier_id") @db.Uuid
  /// Snapshot nome fornitore (display stabile).
  supplierName String            @map("supplier_name")
  /// Location di destinazione merce (il frontend la chiama ancora storeId:
  /// da allineare al wiring — la semantica è location).
  destinationLocationId String   @map("destination_location_id") @db.Uuid
  status     SupplierOrderStatus @default(draft)
  currency   String              @default("EUR")
  totalMinor Int                 @default(0) @map("total_minor")
  expectedAt DateTime?           @map("expected_at")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  supplier            Supplier            @relation(fields: [supplierId], references: [id])
  destinationLocation Location            @relation(fields: [destinationLocationId], references: [id])
  lines               SupplierOrderLine[]

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@map("supplier_orders")
}

model SupplierOrderLine {
  id               String @id @default(uuid()) @db.Uuid
  orderId          String @map("order_id") @db.Uuid
  variantId        String @map("variant_id") @db.Uuid
  /// Snapshot SKU al momento dell'ordine.
  sku              String
  orderedQuantity  Int    @map("ordered_quantity")
  receivedQuantity Int    @default(0) @map("received_quantity")
  unitCostMinor    Int    @map("unit_cost_minor")

  order SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("supplier_order_lines")
}

// ── Clienti e vendite (owner: Shopify per l'ecommerce) ──────────────────────

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String?
  phone     String?
  notes     String?
  addressLine1 String? @map("address_line1")
  addressLine2 String? @map("address_line2")
  city         String?
  province     String?
  postalCode   String? @map("postal_code")
  countryCode  String? @map("country_code")
  shopifyCustomerId String? @map("shopify_customer_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  orders SalesOrder[]

  @@unique([tenantId, shopifyCustomerId])
  @@index([tenantId, lastName])
  @@map("customers")
}

/// Ordini di vendita: read-model nel gestionale (owner Shopify per online/POS;
/// `manual` per vendite registrate direttamente, se mai abilitate).
model SalesOrder {
  id                String                      @id @default(uuid()) @db.Uuid
  tenantId          String                      @map("tenant_id") @db.Uuid
  orderNumber       String                      @map("order_number")
  source            SalesOrderSource            @default(manual)
  financialStatus   SalesOrderFinancialStatus   @default(pending) @map("financial_status")
  fulfillmentStatus SalesOrderFulfillmentStatus @default(unfulfilled) @map("fulfillment_status")
  customerId        String?                     @map("customer_id") @db.Uuid
  /// Snapshot nome cliente (display stabile, anche senza anagrafica).
  customerName      String                      @map("customer_name")
  currency          String                      @default("EUR")
  subtotalMinor     Int                         @default(0) @map("subtotal_minor")
  totalMinor        Int                         @default(0) @map("total_minor")
  placedAt          DateTime                    @map("placed_at")
  shopifyOrderId    String?                     @map("shopify_order_id")
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  customer Customer?        @relation(fields: [customerId], references: [id])
  lines    SalesOrderLine[]

  @@unique([tenantId, shopifyOrderId])
  @@index([tenantId, placedAt(sort: Desc)])
  @@map("sales_orders")
}

model SalesOrderLine {
  id             String  @id @default(uuid()) @db.Uuid
  orderId        String  @map("order_id") @db.Uuid
  /// Nullable: una riga può riferirsi a una variante non più a catalogo.
  variantId      String? @map("variant_id") @db.Uuid
  /// Snapshot SKU e titolo al momento della vendita.
  sku            String
  title          String
  quantity       Int
  unitPriceMinor Int     @map("unit_price_minor")
  totalMinor     Int     @map("total_minor")

  order SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("sales_order_lines")
}

// ── Integrazione Shopify (stato connessione, MAI token nel modello API) ─────

/// Una connessione per tenant. I token OAuth NON vivono qui: stanno cifrati
/// in storage dedicato lato server (o secret manager), mai esposti via API.
model ShopifyConnection {
  id              String                  @id @default(uuid()) @db.Uuid
  tenantId        String                  @unique @map("tenant_id") @db.Uuid
  status          ShopifyConnectionStatus @default(not_connected)
  shopDomain      String?                 @map("shop_domain")
  displayName     String?                 @map("display_name")
  apiVersion      String?                 @map("api_version")
  scopes          String[]                @default([])
  lastConnectedAt DateTime?               @map("last_connected_at")
  lastSyncAt      DateTime?               @map("last_sync_at")
  webhooksActivatedAt DateTime?           @map("webhooks_activated_at")
  webhooksActiveCount Int?                @map("webhooks_active_count")
  /// Webhook Shopify attivi: ordini, clienti, prodotti e giacenze in tempo reale.
  autoSyncEnabled     Boolean               @default(false) @map("auto_sync_enabled")
  lastErrorMessage String?                @map("last_error_message")
  lastErrorCode    String?                @map("last_error_code")
  lastErrorAt      DateTime?              @map("last_error_at")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("shopify_connections")
}

/// Token OAuth cifrato (MAI esposto via API). Una riga per tenant.
model ShopifyCredential {
  tenantId       String   @id @map("tenant_id") @db.Uuid
  shopDomain     String   @map("shop_domain")
  accessTokenEnc String   @map("access_token_enc")
  scopes         String[] @default([])
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("shopify_credentials")
}

/// Stato OAuth monouso (CSRF) con scadenza breve.
model ShopifyOAuthState {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  state      String   @unique
  shopDomain String   @map("shop_domain")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("shopify_oauth_states")
}

// ── Integrazione TikTok Shop (stato connessione, MAI token nel modello API) ─

model TikTokConnection {
  id              String                 @id @default(uuid()) @db.Uuid
  tenantId        String                 @unique @map("tenant_id") @db.Uuid
  status          TikTokConnectionStatus @default(not_connected)
  shopId          String?                @map("shop_id")
  shopCipher      String?                @map("shop_cipher")
  displayName     String?                @map("display_name")
  region          String?
  scopes          String[]               @default([])
  lastConnectedAt DateTime?              @map("last_connected_at")
  lastSyncAt      DateTime?              @map("last_sync_at")
  lastErrorMessage String?               @map("last_error_message")
  lastErrorCode    String?               @map("last_error_code")
  lastErrorAt      DateTime?             @map("last_error_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tiktok_connections")
}

model TikTokCredential {
  tenantId        String   @id @map("tenant_id") @db.Uuid
  shopId          String   @map("shop_id")
  shopCipher      String   @map("shop_cipher")
  accessTokenEnc  String   @map("access_token_enc")
  refreshTokenEnc String   @map("refresh_token_enc")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scopes          String[] @default([])
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tiktok_credentials")
}

model TikTokOAuthState {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  state     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("tiktok_oauth_states")
}

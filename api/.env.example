# PostgreSQL Supabase — Project Settings → Database → Connection string.
# Pooler (6543) per l'app in runtime; diretta (5432) per migrate.
DATABASE_URL=
DIRECT_URL=

# URL pubblico Supabase (Project Settings → API).
SUPABASE_URL=https://<project-ref>.supabase.co

# Service role — SOLO backend. Project Settings → API → Secret keys → Reveal.
# MAI committare, MAI nel frontend.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret (HS256) — Project Settings → API → JWT Settings → JWT Secret.
# Verifica token locale senza chiamata remota getUser su ogni request.
SUPABASE_JWT_SECRET=

# Origini frontend consentite (CORS), separate da virgola.
CORS_ORIGINS=http://localhost:4200

# --- Shopify (opzionale — OAuth + webhook sync) ---
# App custom in Shopify Partners → Client ID / Secret.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_SCOPES=read_orders,read_customers,read_inventory,write_inventory,read_locations,read_products,write_products
# URL pubblico raggiungibile da Shopify (in locale usa ngrok/cloudflared).
SHOPIFY_APP_URL=http://localhost:3000
# Override opzionali (default: SHOPIFY_APP_URL + path API).
# SHOPIFY_OAUTH_CALLBACK_URL=
# SHOPIFY_WEBHOOK_URL=
# Chiave per cifrare access token a riposo (genera stringa random ≥32 char).
SHOPIFY_TOKEN_ENCRYPTION_KEY=
# Throttle outbound Admin API (REST): intervallo minimo tra richieste (ms), retry su 429.
# SHOPIFY_API_MIN_INTERVAL_MS=550
# SHOPIFY_API_MAX_RETRIES=5
# SHOPIFY_API_BUCKET_HIGH_WATERMARK=0.85
# SHOPIFY_API_BUCKET_PAUSE_MS=1000
FRONTEND_URL=http://localhost:4200

# Email operatori VestiFlow abilitati a creare nuovi clienti (tenant), separate da virgola.
# Esempio: tu@vestiflow.com,partner@vestiflow.com
PLATFORM_ADMIN_EMAILS=

# Bucket Supabase Storage public per immagini prodotto (creare da dashboard Supabase).
SUPABASE_PRODUCT_MEDIA_BUCKET=product-media

# PostgreSQL Supabase — Project Settings → Database → Connection string.
# Pooler transaction (6543) per l'app in runtime; session/direct (5432) per migrate.
# Aggiungi ?pgbouncer=true&connection_limit=5 (minimo) — connection_limit=1 causa
# timeout Prisma ("Unable to start a transaction") con richieste concorrenti.
DATABASE_URL=
DIRECT_URL=

# URL pubblico Supabase (Project Settings → API).
SUPABASE_URL=https://<project-ref>.supabase.co

# Service role — SOLO backend. Project Settings → API → Secret keys → Reveal.
# MAI committare, MAI nel frontend.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret (HS256) — Project Settings → API → JWT Settings → JWT Secret.
# Verifica token locale senza chiamata remota getUser su ogni request.
SUPABASE_JWT_SECRET=

# Origini frontend consentite (CORS), separate da virgola.
CORS_ORIGINS=http://localhost:4200

# --- Shopify (opzionale — OAuth + webhook sync) ---
# App custom in Shopify Partners → Client ID / Secret.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_SCOPES=read_orders,read_customers,read_inventory,write_inventory,read_locations,read_products,write_products,read_metaobject_definitions,write_metaobjects
# URL pubblico raggiungibile da Shopify (in locale usa ngrok/cloudflared).
SHOPIFY_APP_URL=http://localhost:3000
# Override opzionali (default: SHOPIFY_APP_URL + path API).
# SHOPIFY_OAUTH_CALLBACK_URL=
# SHOPIFY_WEBHOOK_URL=
# Chiave per cifrare access token a riposo (genera stringa random ≥32 char).
SHOPIFY_TOKEN_ENCRYPTION_KEY=
# Throttle outbound Shopify Admin API (non è billing: limiti tecnici leaky-bucket / costo GraphQL).
# REST: burst adattivo — sotto BURST_RATIO nessun ritardo; vicino al pieno ritarda fino a MIN_INTERVAL_MS.
# SHOPIFY_API_MIN_INTERVAL_MS=500
# SHOPIFY_API_BUCKET_BURST_RATIO=0.25
# SHOPIFY_API_COLD_START_INTERVAL_MS=150
# SHOPIFY_API_MAX_RETRIES=5
# SHOPIFY_API_BUCKET_HIGH_WATERMARK=0.85
# SHOPIFY_API_BUCKET_PAUSE_MS=1000
# GraphQL (taxonomy/metafields): attesa su punti costo + intervallo minimo leggero.
# SHOPIFY_GRAPHQL_MIN_INTERVAL_MS=50
# SHOPIFY_GRAPHQL_COST_RESERVE=100
FRONTEND_URL=http://localhost:4200

# Invito email Supabase al titolare (senza password admin). Default: disabilitato.
# Riattivare con true quando Supabase Pro + SMTP custom (limite ~2 email/ora su free).
# SUPABASE_OWNER_EMAIL_INVITE=false

# Email operatori VestiFlow abilitati a creare nuovi clienti (tenant), separate da virgola.
# Esempio: tu@vestiflow.com,partner@vestiflow.com
PLATFORM_ADMIN_EMAILS=

# Bucket Supabase Storage public per immagini prodotto (creare da dashboard Supabase).
SUPABASE_PRODUCT_MEDIA_BUCKET=product-media

# Bucket Supabase Storage public per foto profilo utente (creare da dashboard Supabase).
SUPABASE_USER_AVATARS_BUCKET=user-avatars

# Bucket Supabase Storage per allegati documento (PDF/XML fatture, DDT).
SUPABASE_DOCUMENT_ATTACHMENTS_BUCKET=document-attachments

# Bucket Supabase Storage per allegati anagrafica fornitore.
SUPABASE_SUPPLIER_ATTACHMENTS_BUCKET=supplier-attachments

# --- Backup locale completo (npm run backup:full) ---
# Passphrase per cifrare il dump Postgres (minimo 16 caratteri). Conservala offline.
BACKUP_ENCRYPTION_PASSPHRASE=
# Su Windows spesso db.*.supabase.co è solo IPv6: usa la URI "Session pooler" porta 5432
# da Supabase → Connect → Session mode (NON transaction :6543). Opzionale se DIRECT_URL funziona.
BACKUP_DATABASE_URL=

# --- TikTok Shop (opzionale — OAuth sync prodotti/giacenze) ---
# App in TikTok Shop Partner Center → App Key / App Secret / Service ID.
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_SERVICE_ID=
# URL pubblico API (default: SHOPIFY_APP_URL se omesso).
# TIKTOK_APP_URL=http://localhost:3000
# TIKTOK_OAUTH_CALLBACK_URL=
TIKTOK_TOKEN_ENCRYPTION_KEY=
# Base API EU (default open-api.tiktokglobalshop.com).
# TIKTOK_API_BASE_URL=https://open-api.tiktokglobalshop.com
# TIKTOK_AUTH_BASE_URL=https://auth.tiktok-shops.com
# TIKTOK_AUTHORIZE_BASE_URL=https://services.tiktokshop.com/open/authorize
# TIKTOK_API_VERSION=202309
# Categoria TikTok di fallback per prodotti senza tiktokCategoryId.
# TIKTOK_DEFAULT_CATEGORY_ID=

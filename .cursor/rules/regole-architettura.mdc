# ANATOMIA DEL FILE `.ts` — Ordine Obbligatorio

```typescript
// 1. Imports Angular core
// 2. Imports Angular common / router / forms
// 3. Imports librerie terze
// 4. Imports interni (ordine: @core → @shared → @features → relativi)
// 5. Imports di tipi (con `import type`) raggruppati alla fine

@Component({ ... })
export class NomeComponent {

  // ── 1. INJECT (dipendenze via inject()) ───────────────────────────
  private readonly nomeService = inject(NomeService);
  private readonly router      = inject(Router);

  // ── 2. INPUT SIGNALS ──────────────────────────────────────────────
  readonly titolo = input.required<string>();
  readonly variant = input<'primary' | 'ghost'>('primary');

  // ── 3. OUTPUT SIGNALS ─────────────────────────────────────────────
  readonly clicked = output<void>();

  // ── 4. MODEL (two-way) ────────────────────────────────────────────
  readonly value = model<string>('');

  // ── 5. STATE SIGNALS (interni) ────────────────────────────────────
  private readonly _count = signal(0);
  readonly count = this._count.asReadonly();

  // ── 6. COMPUTED ───────────────────────────────────────────────────
  readonly label = computed(() => `Totale: ${this._count()}`);

  // ── 7. LIFECYCLE / EFFECTS ────────────────────────────────────────
  constructor() {
    effect(() => { /* side effect reattivo */ });
  }

  // ── 8. METODI PUBBLICI (chiamati dal template) ────────────────────
  onButtonClick(): void { ... }

  // ── 9. METODI PRIVATI ─────────────────────────────────────────────
  private formatData(data: RawData): FormattedData { ... }
}
```


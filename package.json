{
  "name": "vestiflow",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:api": "npm run start:dev --prefix api",
    "start:dev": "npm run start:dev --prefix api",
    "build": "ng build",
    "build:firebase": "node scripts/generate-environment-prod.mjs && ng build",
    "build:pwa": "ng build --configuration=production",
    "build:pwa:local": "ng build --configuration=pwa-local",
    "serve:pwa": "npx http-server dist/vestiflow/browser -p 4200 -c-1",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --watch=false --coverage --exclude \"**/*.component.spec.ts\"",
    "test:components": "ng test --watch=false --include \"**/*.component.spec.ts\" --coverage=false",
    "test:api": "npm run test --prefix api",
    "test:everything": "npm run test:coverage && npm run test:components && npm run test:api",
    "test:all": "npm run test:everything",
    "test:coverage:all": "npm run test:coverage && npm run test:components && npm run test:coverage --prefix api",
    "test:coverage:check": "npm run test:coverage:all",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headless": "playwright test",
    "e2e:ci": "playwright test --project=chromium-guest --project=chromium-ci",
    "e2e:authenticated": "playwright test --project=setup --project=chromium --project=mobile-chrome",
    "e2e:guest": "playwright test --project=chromium-guest",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "audit:lhci": "lhci autorun",
    "check:rls": "node scripts/check-rls.mjs",
    "docs:guide": "node scripts/generate-guide-html.mjs",
    "docs:guide:pdf": "node scripts/generate-guide-pdf.mjs",
    "docs:guide:all": "npm run docs:guide && npm run docs:guide:pdf",
    "docs:test-plan": "node scripts/generate-test-plan-html.mjs",
    "docs:test-plan:pdf": "node scripts/generate-test-plan-pdf.mjs",
    "docs:test-plan:all": "npm run docs:test-plan && npm run docs:test-plan:pdf",
    "icons:generate": "node scripts/generate-icons.mjs",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22.13.0 <23.0.0"
  },
  "overrides": {
    "@babel/core": "^7.29.7",
    "esbuild": "^0.28.1",
    "vite": "^7.3.5",
    "piscina": "5.2.0",
    "undici": "7.28.0"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.16",
    "@fontsource-variable/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.108.1",
    "jsbarcode": "^3.12.3",
    "primeicons": "^7.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@smarttools/eslint-plugin-rxjs": "^1.0.22",
    "@testing-library/angular": "^19.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^20.17.19",
    "@vitest/coverage-v8": "^4.0.8",
    "angular-eslint": "^21.4.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "marked": "^15.0.12",
    "marked-gfm-heading-id": "^4.1.4",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "src/**/*.{ts,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "e2e/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "playwright.config.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,scss,yaml,yml}": [
      "prettier --write"
    ]
  },
  "volta": {
    "node": "22.13.1"
  }
}

{
  "name": "vestiflow",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:api": "npm run start:dev --prefix api",
    "start:dev": "npm run start:dev --prefix api",
    "build": "ng build",
    "apphosting:build": "node scripts/generate-environment-prod.mjs && ng build",
    "build:firebase": "node scripts/generate-environment-prod.mjs && ng build",
    "build:pwa": "ng build --configuration=production",
    "build:pwa:local": "ng build --configuration=pwa-local",
    "serve:pwa": "npx http-server dist/vestiflow/browser -p 4200 -c-1",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.16",
    "@fontsource-variable/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.108.1",
    "primeicons": "^7.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@smarttools/eslint-plugin-rxjs": "^1.0.22",
    "@types/node": "^20.17.19",
    "angular-eslint": "^21.4.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*.{ts,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,scss,yaml,yml}": [
      "prettier --write"
    ]
  }
}

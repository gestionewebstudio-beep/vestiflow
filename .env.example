# VestiFlow — frontend environment (PUBLIC values only)
#
# REGOLA ZERO: nessun segreto qui dentro. Questo file documenta SOLO valori
# pubblici inclusi nel bundle JS (URL, ID pubblici, flag). Token/secret di
# Firebase Admin, Shopify Admin API, DB connection string vivono SOLO nel backend.
#
# Copia questo file in `.env` (gitignored) per lo sviluppo locale.

# --- API ---
# Base URL del backend (NestJS). In locale punta al server di sviluppo.
VESTIFLOW_API_BASE_URL=http://localhost:3000/api

# --- Firebase Auth (config pubblica, NON segreta) ---
# La Firebase web config e' pubblica by design. Restringi via Firebase rules + domini autorizzati.
VESTIFLOW_FIREBASE_API_KEY=
VESTIFLOW_FIREBASE_AUTH_DOMAIN=
VESTIFLOW_FIREBASE_PROJECT_ID=

# --- Feature flags ---
VESTIFLOW_ENABLE_BARCODE_SCANNER=true
VESTIFLOW_ENABLE_SHOPIFY=false

# --- Note Shopify ---
# Nessun token/secret Shopify nel frontend. Lo stato connessione e il sync
# passano sempre dal backend. Qui al massimo identificatori pubblici di debug.

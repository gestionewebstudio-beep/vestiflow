# VestiFlow — frontend environment (PUBLIC values only)
#
# REGOLA ZERO: nessun segreto qui dentro. Questo file documenta SOLO valori
# pubblici inclusi nel bundle JS (URL, ID pubblici, flag). Token/secret di
# Firebase Admin, Shopify Admin API, DB connection string vivono SOLO nel backend.
#
# Copia questo file in `.env` (gitignored) per lo sviluppo locale.

# --- API (build produzione / Firebase App Hosting) ---
# URL pubblico HTTPS del backend NestJS (Railway, Cloud Run, ecc.).
VESTIFLOW_API_BASE_URL=https://YOUR-API.up.railway.app/api/v1

# --- API (locale) ---
# Per sviluppo: in environment.ts usa http://localhost:3000/api/v1
# Per build prod: imposta VESTIFLOW_API_BASE_URL (vedi sopra) prima di npm run build

# --- Supabase Auth (frontend — anon/publishable key, pubblica by design) ---
VESTIFLOW_SUPABASE_URL=https://<project-ref>.supabase.co
VESTIFLOW_SUPABASE_ANON_KEY=

# Service role — SOLO api/.env backend, mai qui.

# --- Feature flags ---
VESTIFLOW_ENABLE_BARCODE_SCANNER=true
# Abilita indicatore sync Shopify in topbar (connessione reale via backend).
VESTIFLOW_ENABLE_SHOPIFY=true

# PWA: test locale → npm run build:pwa:local && npm run serve:pwa (con API su :3000)

# --- Playwright E2E (locale / CI — credenziali test, mai account produzione) ---
# Account dedicato al tenant di test, preferibilmente senza MFA.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
# SKU opzionale: se omesso, i test E2E lo ricavano dal primo prodotto in catalogo.
E2E_TEST_SKU=
# Account clerk opzionale per test permessi (stesso tenant dell'account owner/manager).
# Profilo consigliato per permissions.spec.ts:
# - ruolo commesso, sede operativa assegnata
# - inventory.manage, supplier_orders.receive, reports.view, customers.view, retail.register
# - SENZA catalog.manage, catalog.import_export, inventory.import_export, settings.company
E2E_CLERK_EMAIL=
E2E_CLERK_PASSWORD=
# Commessi granulari E2E (npm run provision:e2e-users — stesso tenant di E2E_USER_*)
# E2E_CLERK_CATALOG_IMPORT_EMAIL=e2e.clerk.catalog-import@vestiflow.test
# E2E_CLERK_CATALOG_IMPORT_PASSWORD=
# E2E_CLERK_INVENTORY_IMPORT_EMAIL=e2e.clerk.inventory-import@vestiflow.test
# E2E_CLERK_INVENTORY_IMPORT_PASSWORD=
# Password condivisa opzionale per tutti i commessi granulari (default script: VestiflowE2e!2026)
# E2E_GRANULAR_PASSWORD=
# E2E_CLERK_MFA_CODE=
# Solo se l'account E2E ha MFA attivo (TOTP monouso al momento del run).
E2E_MFA_CODE=
# Override opzionali (default: http://localhost:4200 e http://localhost:3000)
# E2E_BASE_URL=http://localhost:4200
# E2E_API_URL=http://localhost:3000
# Salta avvio automatico di frontend/API se già in esecuzione:
# E2E_SKIP_WEBSERVER=true

# --- Note Shopify ---
# Nessun token/secret Shopify nel frontend. OAuth, token cifrati e webhook
# passano SOLO dal backend (api/.env: SHOPIFY_*). In locale serve un tunnel
# pubblico (ngrok/cloudflared) per SHOPIFY_APP_URL e webhook.
